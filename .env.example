# Public Supabase project values. Keep the URL at the project root (no /rest/v1 suffix).
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Public Web Push application key. This is safe to expose to the browser.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Server-only notification values. Never prefix these with NEXT_PUBLIC_.
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Shared only by Vercel and the Supabase Cron job. Use a long random value.
CRON_SECRET=your-long-random-cron-secret

# Calendar date/time values are interpreted in this IANA timezone.
CREATOR_OS_TIME_ZONE=Asia/Kolkata
